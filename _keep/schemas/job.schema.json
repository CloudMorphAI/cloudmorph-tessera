{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Control Center Job",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "jobId",
    "requestId",
    "status",
    "executorTarget",
    "payload",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "jobId": {
      "type": "string",
      "description": "Unique job identifier."
    },
    "requestId": {
      "type": "string",
      "description": "Associated request identifier."
    },
    "status": {
      "type": "string",
      "enum": ["queued", "running", "completed", "failed", "cancelled"],
      "description": "Current job status."
    },
    "executorTarget": {
      "type": "string",
      "description": "Executor target (e.g. account or environment selector)."
    },
    "payload": {
      "type": "object",
      "description": "Execution payload for the job.",
      "additionalProperties": true
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp when the job was created."
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp when the job was last updated."
    },
    "artifacts": {
      "type": "array",
      "description": "Artifact pointers produced by the executor.",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "leaseUntil": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "Lease expiry timestamp for the current executor claim."
    },
    "claimedBy": {
      "type": ["string", "null"],
      "description": "Executor identifier currently holding the lease."
    },
    "attempts": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of claim attempts."
    },
    "jobToken": {
      "type": "string",
      "readOnly": true,
      "description": "Ephemeral job token returned on claim (not stored long-term)."
    }
  }
}
