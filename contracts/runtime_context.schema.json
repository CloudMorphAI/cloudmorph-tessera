{
  "$id": "https://contracts.cloudmorph.io/v0.1/runtime-context.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Runtime Context",
  "description": "Context describing who/where the agent is calling from. Passed with every ToolCallRequest. Optional in MVP — defaults to whatever the MCP server can derive from the connection.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "sessionId", "agentIdentity", "capturedAt"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+$"
    },
    "sessionId": { "type": "string" },
    "agentIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 200 },
        "version": { "type": "string", "minLength": 1, "maxLength": 100 },
        "vendor": { "type": "string" },
        "build": { "type": "string", "description": "Optional build identifier (sha, build id)." }
      }
    },
    "hostEnv": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "platform": {
          "type": "string",
          "enum": ["linux", "darwin", "win32", "other"]
        },
        "containerized": { "type": "boolean" },
        "kubernetes": { "type": "boolean" }
      }
    },
    "networkContext": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sourceIp": { "type": "string" },
        "userAgent": { "type": "string", "maxLength": 500 }
      }
    },
    "callerChain": {
      "type": "array",
      "description": "Stack of caller services if this request transited multiple proxies (e.g., when wrapped by cloudmorph_proxy upstream of another MCP).",
      "items": { "type": "string" },
      "maxItems": 20
    },
    "sessionTags": {
      "type": "object",
      "description": "Free-form labels customers can attach to a session for filtering. e.g., {environment: production, team: data}.",
      "additionalProperties": { "type": "string", "maxLength": 200 }
    },
    "capturedAt": { "type": "string", "format": "date-time" },
    "x_meta": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
