{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Control Center Request",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "requestId",
    "tenantId",
    "integrationId",
    "action",
    "targets",
    "payload",
    "status",
    "createdAt"
  ],
  "properties": {
    "requestId": {
      "type": "string",
      "description": "Unique request identifier."
    },
    "tenantId": {
      "type": "string",
      "description": "Tenant identifier."
    },
    "integrationId": {
      "type": "string",
      "description": "Integration identifier tied to the request."
    },
    "action": {
      "type": "string",
      "description": "Action name (e.g. agent.run)."
    },
    "targets": {
      "type": "array",
      "description": "Target identifiers for the request.",
      "items": {
        "type": "string"
      }
    },
    "payload": {
      "type": "object",
      "description": "Request payload.",
      "additionalProperties": true
    },
    "status": {
      "type": "string",
      "enum": ["approval_required", "denied", "queued", "running", "completed", "failed", "cancelled"],
      "description": "Current request status."
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp when the request was created."
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp when the request was last updated."
    },
    "approvalId": {
      "type": ["string", "null"],
      "description": "Approval identifier when approval is required."
    },
    "jobId": {
      "type": ["string", "null"],
      "description": "Job identifier when the request is queued/executed."
    },
    "decision": {
      "type": ["string", "null"],
      "description": "Policy decision for the request."
    },
    "reason": {
      "type": ["string", "null"],
      "description": "Reason for the current decision/status."
    }
  }
}
