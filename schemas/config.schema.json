{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tessera Configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "listen": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "host": {"type": "string", "default": "0.0.0.0"},
        "port": {"type": "integer", "minimum": 1, "maximum": 65535, "default": 8080}
      }
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {"type": "string", "enum": ["bearer"], "default": "bearer"}
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sink": {"type": "string", "enum": ["sqlite", "stdout"], "default": "sqlite"},
        "path": {"type": "string"},
        "also_stdout": {"type": "boolean", "default": false}
      }
    },
    "policies": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dir"],
      "properties": {
        "dir": {"type": "string"},
        "reload": {
          "type": "string",
          "enum": ["watch", "sighup", "none"],
          "default": "none"
        },
        "mode": {
          "type": "string",
          "enum": ["enforcement", "log_only", "observation"],
          "default": "log_only"
        },
        "default_action": {
          "type": "string",
          "enum": ["allow", "block"],
          "default": "block"
        }
      }
    },
    "intent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "meta_key": {"type": "string", "default": "tessera_intent"},
        "required": {"type": "boolean", "default": false}
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {"type": "boolean", "default": false},
        "bearer_token_env": {"type": "string", "default": "TESSERA_METRICS_TOKEN"}
      }
    },
    "deployment_id": {"type": "string", "default": "default"},
    "upstreams": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "url"],
        "additionalProperties": false,
        "properties": {
          "name": {"type": "string"},
          "url": {"type": "string", "format": "uri"},
          "timeout_seconds": {"type": "integer", "minimum": 1, "default": 30},
          "credentials": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "header": {"type": "string"},
              "value": {"type": "string"}
            }
          },
          "kind": {
            "type": "string",
            "enum": ["bearer", "aws_mcp"],
            "default": "bearer"
          },
          "aws_region": {"type": "string"},
          "aws_service": {"type": "string", "default": "aws-mcp"},
          "aws_endpoint_override": {"type": "string"},
          "aws_mcp_routing": {
            "type": "string",
            "enum": ["specific-first", "call-aws-only"],
            "default": "specific-first",
            "description": "Routing mode when upstream targets aws-api-mcp-server. 'specific-first' (default per Q2 2026-05-16): use per-service MCP tool when official_mcp_tool_name is set, fall back to call_aws. 'call-aws-only': always route through call_aws."
          },
          "aws_mcp_server": {
            "type": ["string", "null"],
            "default": null,
            "description": "When set to 'aws-api-mcp-server', enables call_aws translation before SigV4 POST. When null (default), pass through unchanged (legacy direct-service routing)."
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "lockdown": {"type": "boolean", "default": false}
      }
    }
  }
}
