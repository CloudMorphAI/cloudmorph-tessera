# .env.example — Tessera environment variables
# Copy to .env and fill in real values. Never commit .env to version control.

# ── Config ──────────────────────────────────────────────────────────────────
TESSERA_CONFIG_PATH=/etc/tessera/tessera.yaml
TESSERA_POLICY_DIR=/etc/tessera/policies
TESSERA_AUDIT_PATH=/var/lib/tessera/audit.db

# ── Auth (choose ONE of the three token sources) ────────────────────────────
# Option 1 — inline multi-token list (name:token pairs, comma-separated)
# TESSERA_BEARER_TOKENS="alice:tk_abc123_REPLACE_ME,bob:tk_def456_REPLACE_ME"

# Option 2 — YAML token file (see tokens.example.yaml)
# TESSERA_BEARER_TOKENS_FILE=/etc/tessera/tokens.yaml

# Option 3 — legacy single token (name="default", scope="default")
# TESSERA_BEARER_TOKEN=tk_REPLACE_ME_minimum_16_chars

# ── Metrics (optional) ──────────────────────────────────────────────────────
# Only used when metrics.enabled: true in tessera.yaml
# TESSERA_METRICS_TOKEN=tk_metrics_REPLACE_ME

# ── Upstream credentials (resolved via ${VAR} in tessera.yaml) ─────────────
AWS_MCP_TOKEN=REPLACE_ME
GITHUB_MCP_TOKEN=REPLACE_ME

# ── Server ──────────────────────────────────────────────────────────────────
TESSERA_LOG_LEVEL=INFO
TESSERA_DEPLOYMENT_ID=default
TESSERA_BIND_HOST=0.0.0.0
TESSERA_BIND_PORT=8080

# ── Pluggable overrides (advanced) ──────────────────────────────────────────
# TESSERA_POLICY_LOADER=tessera.policy.loader:FilesystemPolicyLoader
# TESSERA_AUDIT_SINK=tessera.audit.sinks.sqlite:SqliteSink
# TESSERA_AUTHENTICATOR=tessera.auth.bearer:BearerTokenAuthenticator
