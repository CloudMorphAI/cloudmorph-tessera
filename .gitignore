# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.eggs/
*.egg-info/
dist/
build/
.Python
*.whl

# Virtual environments
venv/
.venv/
.venv-*/
env/
ENV/
.python-version

# Environment and secrets — NEVER commit these
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
# Explicit exception (v0.7.0): placeholder Ed25519 PUBLIC key bundled in the
# OSS package so importers don't fail on file-not-found. Public keys are safe
# to commit. File header documents replacement recipe.
!tessera/auth/oauth_pubkey.pem
credentials.json
service-account.json
*_secret*
*_credential*
# Explicit private key catch
*private_key*
*privatekey*

# Audit log (SQLite default storage — contains tool_call decisions)
*.db
*.sqlite
*.sqlite3
tessera.db
audit.db

# OPA / Rego build artifacts
bundle.tar.gz
*.wasm
.opa/

# Docker
.docker/
docker-compose.override.yml

# Test & coverage artifacts
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
desktop.ini
Thumbs.db

# Build artifacts
*.tgz
*.tar.gz

# SBOM (generated artifact — do not commit)
sbom.json

# Node (removed — Python-only repo; keep entry to prevent accidental re-introduction)
node_modules/

# Test fixtures whitelist — fixtures intentionally contain secret/credential-shaped
# strings so the secret-leak-block policy can be tested. Whitelist must come AFTER
# the *_secret* / *_credential* / *_key* patterns above so it overrides them.
!tests/fixtures/**

# Internal docs — strategy, drafts, operational artifacts. Never for public consumption.
# v1.1-spec.md is the one exception: it's the public-grade archived architecture spec
# that the founder explicitly intended to keep tracked at the v0.1 cleanup.
docs/_internal/**
!docs/_internal/v1.1-spec.md
!docs/_internal/.gitkeep
