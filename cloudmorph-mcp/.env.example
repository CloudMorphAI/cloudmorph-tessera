# ============================================================
# cloudmorph-mcp — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ----------------------------------------------------------
# REQUIRED
# ----------------------------------------------------------

# Base URL of the CloudMorph Control Center API.
# The MCP server proxies all agent requests to this endpoint.
# Example: https://api.yourcontrolcenter.example.com
CONTROL_CENTER_API_URL=https://api.yourcontrolcenter.example.com

# ----------------------------------------------------------
# SERVER
# ----------------------------------------------------------

# HTTP port the MCP server listens on.
# Default: 8080
PORT=8080

# ----------------------------------------------------------
# LOGGING
# ----------------------------------------------------------

# Log verbosity level.
# Allowed values: debug | info | warn | error | silent
# Default: info
MCP_LOG_LEVEL=info

# ----------------------------------------------------------
# CORS
# ----------------------------------------------------------

# Comma-separated list of allowed CORS origins.
# Use * to allow all origins (not recommended for production).
# Example: https://cursor.sh,https://vscode.dev
MCP_ALLOWED_ORIGINS=*

# ----------------------------------------------------------
# RATE LIMITING
# Per-token token-bucket rate limiter (in-memory).
# ----------------------------------------------------------

# Maximum number of requests a single token may make per day (resets at midnight UTC).
# Default: 100
MCP_RATE_LIMIT_DAILY=100

# Maximum number of requests a single token may make per minute (burst protection).
# Default: 30
MCP_RATE_LIMIT_BURST=30

# Maximum number of concurrent in-flight jobs per token.
# Default: 1
MCP_RATE_LIMIT_CONCURRENT=1

# ----------------------------------------------------------
# WEBSOCKET
# ----------------------------------------------------------

# Whether to validate bearer tokens on WebSocket connections by calling the
# Control Center API. Set to "false" to disable (e.g., local development).
# Default: true
MCP_WS_VALIDATE_TOKENS=true

# ----------------------------------------------------------
# EVENT WEBHOOK
# ----------------------------------------------------------

# Shared secret for the POST /mcp/events inbound webhook.
# The Control Center sends events to this endpoint; this secret authenticates it.
# Leave empty to disable secret validation (not recommended for production).
MCP_EVENT_SECRET=

# ----------------------------------------------------------
# WAIT-FOR-TERMINAL BEHAVIOUR
# ----------------------------------------------------------

# Default seconds cloudmorph_request waits for a terminal event when the
# caller passes wait=true but no explicit waitSeconds value.
# Default: 55
MCP_WAIT_SECONDS=55

# Hard cap on waitSeconds accepted from callers. Values above this are clamped.
# Default: 55
MCP_WAIT_MAX_SECONDS=55
